{
	"_version": "1.86.0",
	"$schema": "https://raw.githubusercontent.com/SAP/ui5-manifest/v1.86.0/schema.json",
	"sap.app": {
		"id": "card.explorer.popin.table.card",
		"type": "card",
		"title": "Sample of a Table Card with Pop-in Behavior",
		"subTitle": "Sample of a Table Card with Pop-in Behavior",
		"applicationVersion": {
			"version": "1.0.0"
		},
		"shortTitle": "A short title for this Card",
		"info": "Additional information about this Card",
		"description": "A long description for this Card",
		"tags": {
			"keywords": [
				"Table",
				"Pop-in",
				"Card",
				"Sample"
			]
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "sap-icon://table-view"
		}
	},
	"sap.card": {
		"type": "Table",
		"header": {
			"title": "Table with Pop-in Support"
		},
		"content": {
			"autoPopinMode": true,
			"hiddenInPopin": [
				"Low"
			],
			"row": {
				"columns": [
					{
						"title": "ID",
						"value": "{ID}",
						"importance": "High",
						"identifier": true
					},
					{
						"title": "Full Name",
						"value": "{FullName}",
						"importance": "High"
					},
					{
						"title": "Role",
						"width": "20%",
						"value": "{Role}",
						"importance": "Medium"
					},
					{
						"title": "Department",
						"width": "20%",
						"value": "{Department}",
						"importance": "None"
					},
					{
						"title": "Location",
						"width": "20%",
						"value": "{Location}",
						"importance": "Low"
					},
					{
						"title": "Status",
						"value": "{Status}",
						"importance": "Low",
						"state": "{= ${Status} === 'Active' ? 'Success' : (${Status} === 'Onboarding' ? 'Warning' : 'Error')}",
						"inverted": true,
						"autoPopinWidth": 10
					},
					{
						"title": "Availability",
						"progressIndicator": {
							"percent": "{availability}",
							"text": "{= format.percent(${availability} / 100)}",
							"state": "{statusState}"
						},
						"importance": "High"
					}
				]
			}
		},
		"data": {
			"json": [
				{
